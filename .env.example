# LLM Seeding Configuration
LLM_PROVIDER=anthropic  # anthropic | openai
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Google OAuth (for authenticated features)
# Set up at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Better Auth session secret
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Main domain (for custom domain routing — requests to other hosts are treated as custom domains)
MAIN_DOMAIN=

# Initial admin user (seeded on first startup)
ADMIN_EMAIL=
