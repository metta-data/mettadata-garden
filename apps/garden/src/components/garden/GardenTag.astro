---
interface Props {
  garden: string;
}

const { garden } = Astro.props;

const colors: Record<string, string> = {
  professional: "bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-300",
  spiritual: "bg-purple-100 text-purple-800 dark:bg-purple-900/30 dark:text-purple-300",
  academic: "bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-300",
};

const colorClass = colors[garden] || "bg-gray-100 text-gray-800 dark:bg-gray-800 dark:text-gray-300";
---

<span class={`inline-flex items-center rounded-md px-2 py-0.5 text-xs font-medium ${colorClass}`}>
  {garden}
</span>
