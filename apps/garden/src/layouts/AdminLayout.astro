---
import BaseLayout from "./BaseLayout.astro";
import { getSessionUser } from "../lib/auth";
import { resolveUser, upsertUserOnLogin } from "../lib/roles";

interface Props {
  title: string;
  active: string;
}

const { title, active } = Astro.props;

const user = await getSessionUser(Astro.request.headers, resolveUser, upsertUserOnLogin);
if (!user || user.role !== "admin") {
  return Astro.redirect("/");
}

const navItems = [
  { href: "/admin", label: "Overview", icon: "📊", id: "overview" },
  { href: "/admin/gardens", label: "Gardens", icon: "🌿", id: "gardens" },
  { href: "/admin/folders", label: "Folders", icon: "📁", id: "folders" },
  { href: "/admin/users", label: "Users", icon: "👥", id: "users" },
  { href: "/admin/pages", label: "Pages", icon: "📝", id: "pages" },
  { href: "/admin/templates", label: "Templates", icon: "📄", id: "templates" },
  { href: "/admin/trash", label: "Trash", icon: "🗑️", id: "trash" },
  { href: "/admin/settings", label: "Settings", icon: "⚙️", id: "settings" },
];
---

<BaseLayout title={`Admin — ${title}`}>
  <div class="flex gap-8 max-w-6xl mx-auto">
    <aside class="w-48 shrink-0">
      <nav class="sticky top-24 space-y-1">
        <h2 class="text-xs font-semibold text-[var(--color-text-muted)] uppercase tracking-wider mb-3 px-3">
          Admin
        </h2>
        {navItems.map((item) => (
          <a
            href={item.href}
            class={`flex items-center gap-2 rounded-lg px-3 py-2 text-sm transition-colors ${
              active === item.id
                ? "bg-[var(--color-accent)] text-white font-medium"
                : "text-[var(--color-text-secondary)] hover:bg-[var(--color-surface-hover)] hover:text-[var(--color-text)]"
            }`}
          >
            <span>{item.icon}</span>
            <span>{item.label}</span>
          </a>
        ))}
      </nav>
    </aside>

    <main class="flex-1 min-w-0">
      <slot />
    </main>
  </div>
</BaseLayout>
