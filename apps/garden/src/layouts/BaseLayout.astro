---
import "../styles/global.css";
import { ThemeToggle } from "@mettadata/ui";
import { SearchDialog } from "@mettadata/ui";
import { UserMenu } from "../components/auth/UserMenu";
import { NewNoteButton } from "../components/auth/NewNoteButton";
import { AdminLink } from "../components/auth/AdminLink";
import { getNavPages } from "../lib/pages";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "A digital garden for growing ideas" } = Astro.props;

const navPages = getNavPages();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | Mettadata Garden</title>
    <link rel="icon" type="image/png" href="/logo.png" />
    <script is:inline>
      // Prevent flash of wrong theme
      (function () {
        const theme = localStorage.getItem("theme") || "system";
        if (
          theme === "dark" ||
          (theme === "system" &&
            window.matchMedia("(prefers-color-scheme: dark)").matches)
        ) {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>
  </head>
  <body class="min-h-screen bg-[var(--color-bg)] text-[var(--color-text)]">
    <header
      class="sticky top-0 z-40 border-b border-[var(--color-border)] bg-[var(--color-surface)]/95 backdrop-blur"
    >
      <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3">
        <div class="flex items-center gap-6">
          <a
            href="/"
            class="flex items-center gap-2 text-lg font-bold text-[var(--color-text)] hover:text-[var(--color-accent)] transition-colors"
          >
            <img src="/logo.png" alt="" class="h-7 w-7" />
            Mettadata Garden
          </a>
          <nav class="hidden sm:flex items-center gap-4">
            <a
              href="/garden"
              class="text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-text)] transition-colors"
            >
              Garden
            </a>
            <a
              href="/blog"
              class="text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-text)] transition-colors"
            >
              Blog
            </a>
            {navPages.map((p) => (
              <a
                href={`/${p.slug}`}
                class="text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-text)] transition-colors"
              >
                {p.label}
              </a>
            ))}
            <AdminLink client:load />
          </nav>
        </div>
        <div class="flex items-center gap-2">
          <NewNoteButton client:load />
          <SearchDialog client:load />
          <ThemeToggle client:load />
          <UserMenu client:load />
        </div>
      </div>
    </header>

    <main class="mx-auto max-w-6xl px-4 py-8">
      <slot />
    </main>

    <footer
      class="border-t border-[var(--color-border)] mt-16"
    >
      <div class="mx-auto max-w-6xl px-4 py-6 flex items-center justify-center gap-4 text-sm text-[var(--color-text-muted)]">
        <span>Tended with care.</span>
        <a href="/changelog" class="hover:text-[var(--color-text-secondary)] transition-colors">Changelog</a>
      </div>
    </footer>
  </body>
</html>
