---
import "../styles/global.css";
import { ThemeToggle } from "@mettadata/ui";
import { SearchDialog } from "@mettadata/ui";

interface Props {
  title: string;
  description?: string;
  gardenName: string;
  gardenIcon?: string;
  gardenDisplayName: string;
}

const {
  title,
  description = "A digital garden for growing ideas",
  gardenName,
  gardenIcon,
  gardenDisplayName,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | {gardenDisplayName}</title>
    <link rel="icon" type="image/png" href="/logo.png" />
    <script is:inline>
      (function () {
        const theme = localStorage.getItem("theme") || "system";
        if (
          theme === "dark" ||
          (theme === "system" &&
            window.matchMedia("(prefers-color-scheme: dark)").matches)
        ) {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>
  </head>
  <body class="min-h-screen bg-[var(--color-bg)] text-[var(--color-text)]">
    <header
      class="sticky top-0 z-40 border-b border-[var(--color-border)] bg-[var(--color-surface)]/95 backdrop-blur"
    >
      <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3">
        <a
          href="/"
          class="flex items-center gap-2 text-lg font-bold text-[var(--color-text)] hover:text-[var(--color-accent)] transition-colors"
        >
          {gardenIcon && <span class="text-xl">{gardenIcon}</span>}
          {gardenDisplayName}
        </a>
        <div class="flex items-center gap-2">
          <SearchDialog client:load />
          <ThemeToggle client:load />
        </div>
      </div>
    </header>

    <main class="mx-auto max-w-6xl px-4 py-8">
      <slot />
    </main>

    <footer class="border-t border-[var(--color-border)] mt-16">
      <div class="mx-auto max-w-6xl px-4 py-6 flex items-center justify-center text-sm text-[var(--color-text-muted)]">
        <span>Tended with care.</span>
      </div>
    </footer>

    <script is:inline define:vars={{ gardenName }}>
      // Rewrite wikilinks to use short paths on custom domains
      document.addEventListener("DOMContentLoaded", function () {
        const prefix = "/garden/" + gardenName + "/";
        document.querySelectorAll('a.wikilink[href^="' + prefix + '"]').forEach(function (a) {
          a.setAttribute("href", "/" + a.getAttribute("href").slice(prefix.length));
        });
      });
    </script>
  </body>
</html>
