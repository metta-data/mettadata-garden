---
import BaseLayout from "../../layouts/BaseLayout.astro";
import GardenSiteLayout from "../../layouts/GardenSiteLayout.astro";
import GrowthStage from "../../components/garden/GrowthStage.astro";
import GardenTag from "../../components/garden/GardenTag.astro";
import BackLinks from "../../components/garden/BackLinks.astro";
import { SeedButton } from "../../components/garden/SeedButton";
import { InlineEditor } from "../../components/garden/InlineEditor";
import { isValidGarden } from "../../lib/gardens";
import { readAllNotes } from "../../lib/note-reader";
import { renderMarkdown } from "../../lib/render-markdown";
import { extractFrontmatter, parseFrontmatter } from "../../lib/frontmatter-utils";
import fs from "node:fs";
import path from "node:path";
import { GARDENS_DIR } from "../../lib/paths";

export const prerender = false;

const slug = Astro.params.slug;
if (!slug) {
  return Astro.redirect("/garden");
}

const segments = slug.split("/");

// Check if first segment is a valid garden
let garden: string | undefined;
let noteSlug: string;

if (segments.length >= 2 && isValidGarden(segments[0])) {
  garden = segments[0];
  noteSlug = segments.slice(1).join("/");
} else {
  // Legacy URL: single slug without garden prefix
  // Search all notes for this slug and redirect
  const allNotes = readAllNotes();
  const match = allNotes.find((n) => n.slug === slug);
  if (match) {
    return Astro.redirect(`/garden/${match.garden}/${match.slug}`);
  }
  return new Response("Note not found", { status: 404 });
}

// For private garden, check auth
if (garden === "private") {
  const { getSessionUser } = await import("../../lib/auth");
  const { resolveUser, upsertUserOnLogin } = await import("../../lib/roles");
  const privateUser = await getSessionUser(Astro.request.headers, resolveUser, upsertUserOnLogin);
  if (!privateUser) {
    return Astro.redirect("/");
  }
}

// Read note from filesystem (works for both build-time and runtime-created notes)
const notePath = path.join(GARDENS_DIR, garden, "notes", `${noteSlug}.md`);
if (!fs.existsSync(notePath)) {
  return new Response("Note not found", { status: 404 });
}
const fileContent = fs.readFileSync(notePath, "utf-8");
const extracted = extractFrontmatter(fileContent);
if (!extracted) {
  return new Response("Invalid note format", { status: 400 });
}
const fm = parseFrontmatter(extracted.raw);
const renderedHtml = await renderMarkdown(extracted.body);
const noteBody = extracted.body;

const parseDate = (v: any) => v ? new Date(String(v)) : new Date();
const parseArray = (v: any) => Array.isArray(v) ? v : (typeof v === "string" && v ? v.split(",").map((s: string) => s.trim()) : []);

const noteData = {
  title: String(fm.title || noteSlug),
  description: fm.description ? String(fm.description) : undefined,
  stage: String(fm.stage || "seed"),
  tags: parseArray(fm.tags),
  created: parseDate(fm.created),
  updated: parseDate(fm.updated),
  publish: fm.publish === true || fm.publish === "true",
  seeded: fm.seeded === true || fm.seeded === "true",
  seedSource: fm.seedSource ? String(fm.seedSource) : undefined,
  aliases: parseArray(fm.aliases),
};

const qualifiedNoteId = `${garden}/notes/${noteSlug}`;

// Auto-generate description from body if not set
const description = noteData.description || autoDescription(noteBody);

const isCustomDomain = !!Astro.locals.gardenDomain;
const gardenDomain = Astro.locals.gardenDomain;
const userRole = Astro.locals.user?.role;

function autoDescription(markdown: string): string {
  const plain = markdown
    .replace(/^#{1,6}\s+/gm, "")
    .replace(/\*\*|__/g, "")
    .replace(/\*|_/g, "")
    .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
    .replace(/\[\[(?:\w+\/)?([^\]|]+)(?:\|([^\]]+))?\]\]/g, (_, t, d) => d || t)
    .replace(/!\[.*?\]\(.*?\)/g, "")
    .replace(/`{1,3}[^`]*`{1,3}/g, "")
    .replace(/\n+/g, " ")
    .trim();
  return plain.slice(0, 160);
}
---

{isCustomDomain && gardenDomain ? (
  <GardenSiteLayout
    title={noteData.title}
    description={description}
    gardenName={gardenDomain.name}
    gardenIcon={gardenDomain.icon}
    gardenDisplayName={gardenDomain.display_name}
  >
    <article class="max-w-3xl mx-auto">
      <header class="mb-8">
        <div class="flex items-center gap-2 mb-3">
          <GrowthStage stage={noteData.stage} />
        </div>
        <h1 class="text-3xl font-bold mb-2">{noteData.title}</h1>
        {description && (
          <p class="text-lg text-[var(--color-text-secondary)]">
            {description}
          </p>
        )}
        <div class="flex items-center gap-4 mt-3 text-sm text-[var(--color-text-muted)]">
          <span>
            Created{" "}
            {noteData.created.toLocaleDateString("en-US", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })}
          </span>
          <span>
            Updated{" "}
            {noteData.updated.toLocaleDateString("en-US", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })}
          </span>
        </div>
        {noteData.tags.length > 0 && (
          <div class="flex gap-1.5 mt-3">
            {noteData.tags.map((tag) => (
              <span class="rounded-md bg-[var(--color-bg-secondary)] px-2 py-0.5 text-xs text-[var(--color-text-secondary)]">
                #{tag}
              </span>
            ))}
          </div>
        )}
      </header>

      <SeedButton
        noteSlug={`${garden}/${noteSlug}`}
        noteTitle={noteData.title}
        isSeeded={noteData.seeded}
        garden={garden}
        client:load
      />

      <div class="prose" data-role={userRole}>
        <Fragment set:html={renderedHtml} />
      </div>

      <InlineEditor
        noteSlug={`${garden}/${noteSlug}`}
        noteContent={noteBody}
        garden={garden}
        noteFrontmatter={{
          title: noteData.title,
          aliases: noteData.aliases || [],
          stage: noteData.stage,
          tags: noteData.tags || [],
          created: noteData.created?.toISOString?.()?.split("T")[0] || "",
          updated: noteData.updated?.toISOString?.()?.split("T")[0] || "",
          publish: noteData.publish,
          description: noteData.description || "",
          seeded: noteData.seeded,
          ...(noteData.seedSource ? { seedSource: noteData.seedSource } : {}),
        }}
        client:load
      />

      <BackLinks noteId={qualifiedNoteId} />
    </article>
  </GardenSiteLayout>
) : (
  <BaseLayout title={noteData.title} description={description}>
    <article class="max-w-3xl mx-auto">
      <header class="mb-8">
        <div class="flex items-center gap-2 mb-3">
          <GrowthStage stage={noteData.stage} />
          {garden !== "private" && <GardenTag garden={garden} />}
        </div>
        <h1 class="text-3xl font-bold mb-2">{noteData.title}</h1>
        {description && (
          <p class="text-lg text-[var(--color-text-secondary)]">
            {description}
          </p>
        )}
        <div class="flex items-center gap-4 mt-3 text-sm text-[var(--color-text-muted)]">
          <span>
            Created{" "}
            {noteData.created.toLocaleDateString("en-US", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })}
          </span>
          <span>
            Updated{" "}
            {noteData.updated.toLocaleDateString("en-US", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })}
          </span>
        </div>
        {noteData.tags.length > 0 && (
          <div class="flex gap-1.5 mt-3">
            {noteData.tags.map((tag) => (
              <span class="rounded-md bg-[var(--color-bg-secondary)] px-2 py-0.5 text-xs text-[var(--color-text-secondary)]">
                #{tag}
              </span>
            ))}
          </div>
        )}
      </header>

      <SeedButton
        noteSlug={`${garden}/${noteSlug}`}
        noteTitle={noteData.title}
        isSeeded={noteData.seeded}
        garden={garden}
        client:load
      />

      <div class="prose" data-role={userRole}>
        <Fragment set:html={renderedHtml} />
      </div>

      <InlineEditor
        noteSlug={`${garden}/${noteSlug}`}
        noteContent={noteBody}
        garden={garden}
        noteFrontmatter={{
          title: noteData.title,
          aliases: noteData.aliases || [],
          stage: noteData.stage,
          tags: noteData.tags || [],
          created: noteData.created?.toISOString?.()?.split("T")[0] || "",
          updated: noteData.updated?.toISOString?.()?.split("T")[0] || "",
          publish: noteData.publish,
          description: noteData.description || "",
          seeded: noteData.seeded,
          ...(noteData.seedSource ? { seedSource: noteData.seedSource } : {}),
        }}
        client:load
      />

      <BackLinks noteId={qualifiedNoteId} />
    </article>
  </BaseLayout>
)}
