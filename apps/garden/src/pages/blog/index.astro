---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { getSessionUser } from "../../lib/auth";
import { resolveUser, upsertUserOnLogin } from "../../lib/roles";

export const prerender = false;

// Check auth for draft visibility
const user = await getSessionUser(Astro.request.headers, resolveUser, upsertUserOnLogin);
const isAdmin = user?.role === "admin" || user?.role === "steward";

const allPosts = await getCollection("blog");
const posts = allPosts
  .filter((post) => isAdmin || !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="Blog" description="Thoughts and reflections from the garden">
  <div class="max-w-3xl mx-auto space-y-8">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-3xl font-bold mb-2">Blog</h1>
        <p class="text-[var(--color-text-secondary)]">
          Longer-form writing that weaves together ideas from the garden.
        </p>
      </div>
      {isAdmin && (
        <a
          href="/blog/new"
          class="inline-flex items-center gap-1.5 rounded-lg bg-[var(--color-accent)] px-4 py-2
            text-sm font-medium text-white hover:bg-[var(--color-accent-hover)] transition-colors"
        >
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
          </svg>
          New Post
        </a>
      )}
    </div>

    <div class="space-y-6">
      {posts.map((post) => (
        <article class="rounded-lg border border-[var(--color-border)] p-6 hover:bg-[var(--color-surface-hover)] transition-colors">
          <div class="flex items-start justify-between gap-3">
            <a href={`/blog/${post.id}`} class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-2">
                <h2 class="text-xl font-semibold text-[var(--color-text)] hover:text-[var(--color-accent)]">
                  {post.data.title}
                </h2>
                {post.data.draft && (
                  <span class="rounded bg-yellow-100 dark:bg-yellow-900/30 px-2 py-0.5 text-xs font-medium text-yellow-800 dark:text-yellow-200">
                    Draft
                  </span>
                )}
              </div>
            </a>
            {isAdmin && (
              <a
                href={`/blog/edit/${post.id}`}
                class="shrink-0 text-xs text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors"
              >
                Edit
              </a>
            )}
          </div>
          <p class="text-[var(--color-text-secondary)] mb-3">
            {post.data.description}
          </p>
          <div class="flex items-center gap-3 text-sm text-[var(--color-text-muted)]">
            <time datetime={post.data.date.toISOString()}>
              {post.data.date.toLocaleDateString("en-US", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })}
            </time>
            <div class="flex gap-1.5">
              {post.data.tags.map((tag) => (
                <span class="rounded bg-[var(--color-bg-secondary)] px-1.5 py-0.5 text-xs">
                  #{tag}
                </span>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>
