---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { BlogEditor } from "../../../components/blog/BlogEditor";
import { getSessionUser } from "../../../lib/auth";
import { resolveUser, upsertUserOnLogin } from "../../../lib/roles";
import fs from "node:fs";
import path from "node:path";
import { BLOG_DIR } from "../../../lib/paths";

export const prerender = false;

// Auth check
const user = await getSessionUser(Astro.request.headers, resolveUser, upsertUserOnLogin);
if (!user || (user.role !== "admin" && user.role !== "steward")) {
  return Astro.redirect("/");
}

const slug = Astro.params.slug;
if (!slug) {
  return Astro.redirect("/blog");
}

// Read the post file
const filePath = path.join(BLOG_DIR, `${slug}.md`);

if (!fs.existsSync(filePath)) {
  return new Response("Post not found", { status: 404 });
}

const fileContent = fs.readFileSync(filePath, "utf-8");
const fmMatch = fileContent.match(/^---\n([\s\S]*?)\n---/);
if (!fmMatch) {
  return new Response("Invalid post format", { status: 400 });
}

// Simple frontmatter parsing for props
const fmRaw = fmMatch[1];
const body = fileContent.replace(/^---\n[\s\S]*?\n---/, "").trim();

// Parse frontmatter into object
function parseFm(raw: string): Record<string, any> {
  const result: Record<string, any> = {};
  for (const line of raw.split("\n")) {
    const match = line.match(/^(\w[\w-]*):\s*(.*)/);
    if (!match) continue;
    const [, key, rawValue] = match;
    const value = rawValue.trim();
    if (value.startsWith("[") && value.endsWith("]")) {
      const inner = value.slice(1, -1);
      result[key] = inner.trim() === "" ? [] : inner.split(",").map((v) => v.trim().replace(/^["']|["']$/g, "")).filter(Boolean);
    } else if (value === "true") {
      result[key] = true;
    } else if (value === "false") {
      result[key] = false;
    } else if ((value.startsWith('"') && value.endsWith('"')) || (value.startsWith("'") && value.endsWith("'"))) {
      result[key] = value.slice(1, -1);
    } else {
      result[key] = value;
    }
  }
  return result;
}

const frontmatter = parseFm(fmRaw);
---

<BaseLayout title={`Edit: ${frontmatter.title || slug}`}>
  <BlogEditor
    client:load
    existingSlug={slug}
    existingContent={body}
    existingFrontmatter={frontmatter}
  />
</BaseLayout>
