---
import BaseLayout from "../layouts/BaseLayout.astro";

export const prerender = false;

// Read the changelog at runtime (works in both dev and prod)
import fs from "node:fs";
import path from "node:path";
import { fileURLToPath } from "node:url";

const __dirname = path.dirname(fileURLToPath(import.meta.url));
// In dev: src/pages, go up to src/content. In prod: resolve from project root.
let changelogContent = "";
const possiblePaths = [
  path.resolve(__dirname, "../content/changelog.md"),
  path.resolve(__dirname, "../../src/content/changelog.md"),
  path.resolve(process.cwd(), "src/content/changelog.md"),
];
for (const p of possiblePaths) {
  if (fs.existsSync(p)) {
    changelogContent = fs.readFileSync(p, "utf-8");
    break;
  }
}

// Remove the leading "# Changelog" since we'll render it in the page
const body = changelogContent.replace(/^# Changelog\s*\n/, "");
---

<BaseLayout title="Changelog" description="What's new and what's coming to Mettadata Garden">
  <div class="max-w-3xl mx-auto">
    <h1 class="text-3xl font-bold mb-2">Changelog</h1>
    <p class="text-[var(--color-text-secondary)] mb-8">
      All notable changes to Mettadata Garden.
      Format based on <a href="https://keepachangelog.com/en/1.1.0/" class="text-[var(--color-accent)] hover:underline">Keep a Changelog</a>.
    </p>

    {body.split(/\n(?=## )/).map((section) => {
      if (!section.trim()) return null;
      const lines = section.trim().split("\n");
      const heading = lines[0].replace(/^## /, "");
      const content = lines.slice(1).join("\n");

      return (
        <section class="mb-8">
          <h2 class="text-xl font-bold border-b border-[var(--color-border)] pb-2 mb-4">
            {heading}
          </h2>
          {content.split(/\n(?=### )/).map((sub) => {
            if (!sub.trim()) return null;
            const subLines = sub.trim().split("\n");
            const subHeading = subLines[0].replace(/^### /, "");
            const items = subLines.slice(1)
              .filter((l) => l.startsWith("- "))
              .map((l) => l.replace(/^- /, ""));

            if (!subHeading.startsWith("#") && items.length > 0) {
              return (
                <div class="mb-4">
                  <h3 class="text-sm font-semibold uppercase tracking-wide text-[var(--color-text-secondary)] mb-2">
                    {subHeading}
                  </h3>
                  <ul class="space-y-1 ml-4">
                    {items.map((item) => (
                      <li class="text-sm text-[var(--color-text)] before:content-['•'] before:mr-2 before:text-[var(--color-text-muted)]">
                        {item}
                      </li>
                    ))}
                  </ul>
                </div>
              );
            }
            return null;
          })}
        </section>
      );
    })}
  </div>
</BaseLayout>
